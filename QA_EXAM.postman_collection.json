  "item": [
    {
      "name": "User list",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", () => {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const users = pm.response.json();\r",
              "\r",
              "pm.test(\"Each user has id, name, and email\", () => {\r",
              "    users.forEach(user => {\r",
              "        pm.expect(user).to.have.all.keys('id', 'name', 'email', 'gender', 'status');\r",
              "        pm.expect(user.id).to.be.a('number');\r",
              "        pm.expect(user.name).to.be.a('string').and.not.empty;\r",
              "        pm.expect(user.email).to.be.a('string').and.not.empty;\r",
              "    });\r",
              "});\r",
              "\r",
              "pm.test(\"Count users with status = active\", () => {\r",
              "    const activeUsers = users.filter(user => user.status === \"active\");\r",
              "    const activeCount = activeUsers.length;\r",
              "    \r",
              "    console.log(`Active users: ${activeCount}`);\r",
              "    pm.environment.set(\"active_users_count\", activeCount);\r",
              "    \r",
              "    // Assert all filtered users are actually active\r",
              "    activeUsers.forEach(user => {\r",
              "        pm.expect(user.status).to.eql(\"active\");\r",
              "    });\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
