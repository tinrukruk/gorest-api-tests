    {
      "name": "Verify user created",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const response = pm.response.json();\r",
              "\r",
              "pm.test(\"Response contains correct user ID\", function () {\r",
              "    pm.expect(response.id).to.eql(parseInt(pm.environment.get(\"user_id\")));\r",
              "});\r",
              "\r",
              "// Get user_id from environment and parse saved created_user\r",
              "const createdUser = JSON.parse(pm.environment.get(\"created_user\"));\r",
              "\r",
              "pm.test(\"GET response matches POST response\", function () {\r",
              "    pm.expect(response.id).to.eql(createdUser.id);\r",
              "    pm.expect(response.name).to.eql(createdUser.name);\r",
              "    pm.expect(response.email).to.eql(createdUser.email);\r",
              "    pm.expect(response.gender).to.eql(createdUser.gender);\r",
              "    pm.expect(response.status).to.eql(createdUser.status);\r",
              "});\r",
              "\r",
              "pm.test(\"Validate user status is inactive\", function () {\r",
              "    pm.expect(response.status).to.eql(\"inactive\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
