    {
      "name": "User list of active users",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", () => {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const users = pm.response.json();\r",
              "const updatedUser = JSON.parse(pm.environment.get(\"updated_user\"));\r",
              "const targetUserId = updatedUser.id;\r",
              "\r",
              "const targetUser = users.find(user => user.id === targetUserId);\r",
              "\r",
              "//Verify the user details match the updated user\r",
              "pm.test(\"GET response matches PUT response for updated user\", function () {\r",
              "    if (targetUser) {\r",
              "        pm.expect(targetUser.id).to.eql(updatedUser.id);\r",
              "        pm.expect(targetUser.name).to.eql(updatedUser.name);\r",
              "        pm.expect(targetUser.email).to.eql(updatedUser.email);\r",
              "        pm.expect(targetUser.gender).to.eql(updatedUser.gender);\r",
              "        pm.expect(targetUser.status).to.eql(updatedUser.status);\r",
              "    }\r",
              "});\r",
              "\r",
              "pm.test(\"Count users with status = active\", () => {\r",
              "    const activeUsers = users.filter(user => user.status === \"active\");\r",
              "    const activeCount = activeUsers.length;\r",
              "    console.log(`Active users: ${activeCount}`);\r",
              "    pm.environment.set(\"new_active_users_count\", activeCount);\r",
              "    pm.expect(pm.environment.get(\"new_active_users_count\")).to.not.eql(pm.environment.get(\"active_users_count\"));\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
