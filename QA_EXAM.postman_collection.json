    {
      "name": "Create user",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.test(\"Set current date and time\", function () {\r",
              "    const now = new Date();\r",
              "    \r",
              "    const formattedDateTime = \r",
              "        now.getFullYear() +\r",
              "        String(now.getMonth() + 1).padStart(2, '0') +\r",
              "        String(now.getDate()).padStart(2, '0') +\r",
              "        String(now.getHours()).padStart(2, '0') +\r",
              "        String(now.getMinutes()).padStart(2, '0') +\r",
              "        String(now.getSeconds()).padStart(2, '0') +\r",
              "        String(now.getMilliseconds()).padStart(3, '0');\r",
              "    \r",
              "    console.log(\"Timestamp with ms: \" + formattedDateTime);\r",
              "    pm.environment.set(\"currentDateTime\", formattedDateTime);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "const response = pm.response.json();\r",
              "pm.environment.set(\"user_id\", response.id);\r",
              "const currentDateTime = pm.environment.get(\"currentDateTime\");\r",
              "\r",
              "// Validate response matches payload\r",
              "pm.test(\"Response matches payload values\", function () {\r",
              "    pm.expect(response.name).to.eql(\"Ruksith Y\");\r",
              "    pm.expect(response.email).to.eql(`ruksith.${currentDateTime}@testmail.com`);\r",
              "    pm.expect(response.gender).to.eql(\"male\");\r",
              "    pm.expect(response.status).to.eql(\"inactive\");\r",
              "});\r",
              "\r",
              "// Save response body for later comparison\r",
              "pm.environment.set(\"created_user\", JSON.stringify(response));"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
